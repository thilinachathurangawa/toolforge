# ToolForge — Environment Variables
# Copy this file to .env.local and fill in the values

# ── Site ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.toolforge.website

# ── Google Analytics 4 ─────────────────────────────────────────────
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google AdSense ──────────────────────────────────────────────────
# Get from: https://adsense.google.com
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ── Adsterra ────────────────────────────────────────────────────────
# Get from: https://publishers.adsterra.com
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=XXXXXXXXXX
NEXT_PUBLIC_ADSTERRA_SIDEBAR_RECT_KEY=XXXXXXXXXX
NEXT_PUBLIC_ADSTERRA_SIDEBAR_SKYSCRAPER_KEY=XXXXXXXXXX

# ── Adsera ─────────────────────────────────────────────────────────
# Get from: https://adsera.com
NEXT_PUBLIC_ADSERA_SIDEBAR_RECT_KEY=XXXXXXXXXX
NEXT_PUBLIC_ADSERA_SIDEBAR_SKYSCRAPER_KEY=XXXXXXXXXX

# ── Ads Toggle ──────────────────────────────────────────────────────
# Set to 'true' when ad networks are configured and approved
# Set to 'false' during development / before approval
NEXT_PUBLIC_ADS_ENABLED=false

# ── Email (Contact Form) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Required for the contact form to send emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
